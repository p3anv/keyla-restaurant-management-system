generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum UserRole {
  ADMIN
  MANAGER
  WAITER
  CHEF
}

enum TableStatus {
  FREE
  OCCUPIED
  RESERVED
  OUT_OF_SERVICE
}

enum OrderStatus {
  PENDING      // Order placed, waiting for kitchen
  PREPARING    // Kitchen is cooking
  READY        // Food is ready to serve
  COMPLETED    // Paid and closed
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  UPI
  GIFT_CARD
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum CourseType {
  STARTER
  MAIN
  DESSERT
  BEVERAGE
}

enum TaxCategory {
  FOOD        // Standard rate (e.g., 5%)
  BEVERAGE    // Higher rate (e.g., 18%)
  ALCOHOL     // Highest rate (e.g., 25%)
}

// ==================== CORE TABLES ====================

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         UserRole @default(WAITER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders       Order[]  @relation("WaiterOrders")

  @@map("users")
}

model Table {
  id           String      @id @default(cuid())
  tableNumber  Int         @unique
  capacity     Int
  status       TableStatus @default(FREE)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  orders       Order[]

  @@map("tables")
}

model MenuItem {
  id            String      @id @default(cuid())
  name          String
  description   String?
  price         Float       @default(0.0)
  imageUrl      String?
  isAvailable   Boolean     @default(true)
  stockQuantity Int         @default(0)   // Simple unit tracking
  course        CourseType  @default(MAIN)
  taxCategory   TaxCategory @default(FOOD)

  categoryId    String
  category      MenuCategory @relation(fields: [categoryId], references: [id])

  modifiers     ModifierGroup[]
  orderItems    OrderItem[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("menu_items")
}

model MenuCategory {
  id           String     @id @default(cuid())
  name         String     @unique
  displayOrder Int        @default(0)
  items        MenuItem[]

  @@map("menu_categories")
}

model ModifierGroup {
  id           String   @id @default(cuid())
  name         String
  minSelect    Int      @default(0)
  maxSelect    Int      @default(1)

  menuItemId   String
  menuItem     MenuItem @relation(fields: [menuItemId], references: [id])

  options      ModifierOption[]

  @@map("modifier_groups")
}

model ModifierOption {
  id               String        @id @default(cuid())
  name             String
  priceAdjustment  Float         @default(0.0)
  groupId          String
  group            ModifierGroup @relation(fields: [groupId], references: [id])

  @@map("modifier_options")
}

model Order {
  id           String      @id @default(cuid())
  orderNumber  Int         @default(autoincrement())
  status       OrderStatus @default(PENDING)
  
  subtotal     Float       @default(0.0)
  taxAmount    Float       @default(0.0)
  discount     Float       @default(0.0)
  total        Float       @default(0.0)

  guestCount   Int         @default(1)

  tableId      String
  table        Table       @relation(fields: [tableId], references: [id])
  
  waiterId     String
  waiter       User        @relation("WaiterOrders", fields: [waiterId], references: [id])

  items        OrderItem[]
  payments     Payment[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tableId])
  @@index([waiterId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id            String    @id @default(cuid())
  quantity      Int       @default(1)
  unitPrice     Float
  totalPrice    Float
  
  taxRate       Float
  taxAmount     Float

  modifierData  Json?

  orderId       String
  order         Order     @relation(fields: [orderId], references: [id])

  menuItemId    String
  menuItem      MenuItem  @relation(fields: [menuItemId], references: [id])

  @@map("order_items")
}

model Payment {
  id           String        @id @default(cuid())
  amount       Float
  method       PaymentMethod
  status       PaymentStatus @default(PENDING)
  transactionId String?

  orderId      String
  order        Order         @relation(fields: [orderId], references: [id])

  processedAt  DateTime      @default(now())

  @@map("payments")
}

model Setting {
  id           String   @id @default(cuid())
  key          String   @unique
  value        String
  description  String?

  @@map("settings")
}